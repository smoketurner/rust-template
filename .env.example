# Environment variables for local development.
# Copy to .env (gitignored) and adjust. The server reads these at startup.

# Logging filter — see https://docs.rs/tracing-subscriber filter syntax.
RUST_LOG=info

# Database connection. The scheme selects the backend (see docs/database.md):
#   in-memory (tests): sqlite::memory:
#   local file:        sqlite://app.db?mode=rwc
#   Aurora DSQL:       postgres://admin@<cluster>.dsql.<region>.on.aws/postgres
DATABASE_URL=sqlite://app.db?mode=rwc

# AWS — only needed when DATABASE_URL points at Aurora DSQL.
# AWS_REGION=us-east-1
# AWS_PROFILE=

# Server bind address (host:port).
# BIND_ADDR=[::1]:3000
